{
  "name": "hub",
  "version": "0.3.0",
  "private": true,
  "description": "Personal AI operating layer — TS monorepo on Claude Agent SDK + MCP.",
  "engines": {
    "node": ">=22.5.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm typecheck:api && pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm test:api && pnpm -r test",
    "typecheck:api": "tsc -p tsconfig.api.json",
    "test:api": "vitest run api/_lib/console-store.test.ts",
    "verify": "pnpm format:check && pnpm lint && pnpm build && pnpm typecheck && pnpm test",
    "security:secrets": "gitleaks detect --no-git --source . --config .gitleaks.toml --redact --verbose",
    "dev": "pnpm -r --parallel --filter @hub/server --filter @hub/web dev",
    "dev:server": "pnpm --filter @hub/server dev",
    "dev:web": "pnpm --filter @hub/web dev",
    "migrate:hub:supabase": "node --no-warnings=ExperimentalWarning scripts/export-sqlite-to-supabase.mjs",
    "serve": "pnpm build && node --no-warnings=ExperimentalWarning apps/server/dist/main.js",
    "hub": "node --no-warnings=ExperimentalWarning apps/cli/dist/main.js",
    "clean": "pnpm -r exec rimraf dist node_modules .turbo && rimraf node_modules",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.0",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.0"
  }
}
