{
  "name": "@hub/agent-runtime",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./run": {
      "types": "./dist/run.d.ts",
      "default": "./dist/run.js"
    },
    "./mcp-config": {
      "types": "./dist/mcp-config.d.ts",
      "default": "./dist/mcp-config.js"
    },
    "./persist": {
      "types": "./dist/persist.d.ts",
      "default": "./dist/persist.js"
    },
    "./brief": {
      "types": "./dist/brief.d.ts",
      "default": "./dist/brief.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "@anthropic-ai/sdk": "^0.90.0",
    "@hub/db": "workspace:*",
    "@hub/models": "workspace:*",
    "@hub/shared": "workspace:*",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
