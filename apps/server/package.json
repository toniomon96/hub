{
  "name": "@hub/server",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hub/agent-runtime": "workspace:*",
    "@hub/capture": "workspace:*",
    "@hub/db": "workspace:*",
    "@hub/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.16"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.4"
  }
}
