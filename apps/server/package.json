{
  "name": "@hub/server",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch --onSuccess \"node --no-warnings=ExperimentalWarning dist/main.js\"",
    "dev:tsx": "tsx watch src/main.ts",
    "start": "node --no-warnings=ExperimentalWarning dist/main.js",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-openapi": "^0.18.3",
    "@hub/agent-runtime": "workspace:*",
    "@hub/capture": "workspace:*",
    "@hub/db": "workspace:*",
    "@hub/prompts": "workspace:*",
    "@hub/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.16",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@hub/models": "workspace:*",
    "@types/node-cron": "^3.0.11",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  }
}
