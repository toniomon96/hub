# Hub VPS .env template. Copy to ../.env on the VPS and fill in.
# Never commit the filled-in version. Generate random secrets with
#   openssl rand -hex 32

# --- Anthropic (ROTATE from whatever was on the laptop) ---
ANTHROPIC_API_KEY=

# --- Server — bind all interfaces; cloudflared reaches us on localhost ---
HUB_PORT=4567
HUB_HOST=0.0.0.0
HUB_TIMEZONE=America/Chicago

# --- Paths (match setup-vps.sh + systemd units) ---
HUB_DB_PATH=/var/lib/hub/data/hub.db
HUB_LOG_DIR=/var/lib/hub/logs
OBSIDIAN_VAULT_PATH=/var/lib/hub/vault

# --- Shared secrets (ROTATE — do not reuse laptop values) ---
HUB_WEBHOOK_SECRET=
HUB_UI_TOKEN=
# HUB_COOKIE_SECRET signs UI session cookies. MUST differ from HUB_UI_TOKEN
# in production (server refuses to boot with NODE_ENV=production otherwise).
# Generate with `openssl rand -hex 32` or `pwsh -c "[Convert]::ToBase64String((1..32 | % { Get-Random -Max 256 }))"`.
HUB_COOKIE_SECRET=

# --- Models (router defaults; phi4-mini is the only one we pull on CX22) ---
HUB_DEFAULT_MODEL=claude-sonnet-4-5
HUB_LOCAL_MODEL_TRIVIAL=phi4-mini
HUB_LOCAL_MODEL_PRIVATE=phi4-mini
HUB_LOCAL_MODEL_FALLBACK=phi4-mini
OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- Daily cost ceiling ---
HUB_DAILY_USD_CAP=5

# --- Brief scheduler (set to 1 to enable cron; leave 0 on first boot) ---
HUB_BRIEF_ENABLED=0

# --- MCP allowlist (set to 1 to drop MCP servers not on the hardcoded
# allowlist; v0.4 default is permissive, flips to '1' in v0.6) ---
HUB_MCP_STRICT=0

# --- Logging ---
HUB_LOG_LEVEL=info

# --- Integrations (leave blank on first boot; brief degrades gracefully) ---
NOTION_TOKEN=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
TODOIST_API_TOKEN=
TODOIST_MCP_PATH=
GITHUB_PAT=
OBSIDIAN_API_KEY=

# --- Alerts (optional) ---
NTFY_TOPIC=
