{
  "buildCommand": "pnpm --filter @hub/web build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://hubserver-production-0cd1.up.railway.app/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://hubserver-production-0cd1.up.railway.app/auth/:path*"
    },
    {
      "source": "/webhooks/:path*",
      "destination": "https://hubserver-production-0cd1.up.railway.app/webhooks/:path*"
    },
    {
      "source": "/health",
      "destination": "https://hubserver-production-0cd1.up.railway.app/health"
    }
  ]
}
