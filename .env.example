# =====================================================================
# Hub configuration. Copy to .env and fill in. NEVER commit .env.
# Long-lived tokens should move to OS keychain (@napi-rs/keyring) post-MVP.
# =====================================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Model defaults (override per-call via router) ---
HUB_DEFAULT_MODEL=claude-sonnet-4-5
HUB_LOCAL_MODEL_TRIVIAL=phi4-mini
HUB_LOCAL_MODEL_PRIVATE=qwen3:7b
HUB_LOCAL_MODEL_FALLBACK=llama3.3

# --- Ollama ---
OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- Notion ---
NOTION_TOKEN=
NOTION_VERSION=2025-09-03

# --- Obsidian (Local REST API plugin) ---
OBSIDIAN_API_KEY=
OBSIDIAN_HOST=127.0.0.1
OBSIDIAN_PORT=27123
OBSIDIAN_VAULT_PATH=

# --- Google Workspace (workspace-mcp) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Todoist (sjvadrevu MCP — permanent token, NOT OAuth) ---
TODOIST_API_TOKEN=
TODOIST_MCP_PATH=./vendor/todoist-mcp-server/dist/index.js

# --- Linear (remote MCP, OAuth handled by SDK) ---
# no env needed; SDK manages OAuth

# --- GitHub ---
GITHUB_PAT=

# --- Server ---
HUB_PORT=4567
HUB_HOST=127.0.0.1
HUB_TIMEZONE=America/Chicago

# --- Brief scheduler ---
# When set to '1', the server runs node-cron jobs:
#   05:00  morning brief     22:00  nightly brief
#   Fri 17:00  week retro    Sun 18:00  week planning
# Leave at 0 in dev so you don't spend Anthropic credits in your sleep.
HUB_BRIEF_ENABLED=0

# --- Database ---
HUB_DB_PATH=./data/hub.db

# --- Logging ---
HUB_LOG_LEVEL=info
HUB_LOG_DIR=./logs

# --- Notifications ---
# Create a topic at https://ntfy.sh/<your-topic> (no signup required).
# When set, cron failures and /healthz state changes post here.
NTFY_TOPIC=
NTFY_URL=https://ntfy.sh

# --- Backup monitoring ---
# When HUB_BACKUP_DIR is set, /healthz reports `backup.ok=false` if the
# newest *.db file is older than HUB_BACKUP_MAX_AGE_H hours. Leave
# HUB_BACKUP_DIR unset in dev.
HUB_BACKUP_DIR=
HUB_BACKUP_MAX_AGE_H=26

# --- Privacy router (load-bearing: enforced from MVP day 1) ---
# Comma-separated regex patterns. Match in user input => route to local SLM, never Anthropic.
HUB_SENSITIVITY_PATTERNS=medical|prescription|diagnosis|therapist,SSN|social.security,bank.*account|routing.*number,salary|compensation,family|wife|kid|child

# --- Cost ceiling ---
# When today's cumulative Anthropic spend reaches this USD cap, the router
# silently downgrades cloud routes to HUB_LOCAL_MODEL_FALLBACK. 0 disables.
HUB_DAILY_USD_CAP=5

# --- Webhook shared secret ---
# Required for all /webhooks/* endpoints (Superwhisper, Granola, etc.).
# Empty => server returns 503 on every webhook. Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
HUB_WEBHOOK_SECRET=

# --- Web UI auth token ---
# Gates /api/* for the browser UI. Same value is also accepted as
# `x-hub-secret` header for CLI/tool access. Kept separate from
# HUB_WEBHOOK_SECRET so blast radius is isolated.
# Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
HUB_UI_TOKEN=

# Optional — override cookie-signing secret. Defaults to HUB_UI_TOKEN itself,
# which is usually what you want (rotating the token invalidates all cookies).
HUB_COOKIE_SECRET=

# --- Consulting console full-stack ops (Vercel Functions + Supabase) ---
# Server-only. Never expose the secret/service key to browser code.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# Legacy Supabase projects can use SUPABASE_SERVICE_ROLE_KEY instead.
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# Console markdown/manifest source adapter.
# local = read sibling engineering-playbook checkout in local dev.
# github = read engineering-playbook and portfolio manifests from GitHub in Vercel.
CONSOLE_SOURCE_ADAPTER=local
CONSOLE_PLAYBOOK_LOCAL_PATH=../engineering-playbook
CONSOLE_PLAYBOOK_REPO=
CONSOLE_PLAYBOOK_REF=main
CONSOLE_PORTFOLIO_REPOS=
CONSOLE_CURRENT_PHASE=

# Public intake endpoint allowlist. Comma-separated origins. Leave blank in
# early preview if the intake endpoint is only reached by normal form POST.
CONSULTING_INTAKE_ALLOWED_ORIGINS=https://tonimontez.co,https://www.tonimontez.co
CONSULTING_INTAKE_SUCCESS_URL=https://tonimontez.co/start

# Vercel webhook routes use vendor-specific secrets when present and fall back
# to HUB_WEBHOOK_SECRET for manual/superwhisper and legacy senders.
HUB_WEBHOOK_SECRET=
HUB_WEBHOOK_SECRET_GRANOLA=
HUB_WEBHOOK_SECRET_PLAUD=
HUB_WEBHOOK_SECRET_MARTIN=
