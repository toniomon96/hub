# =====================================================================
# Hub configuration. Copy to .env and fill in. NEVER commit .env.
# Long-lived tokens should move to OS keychain (@napi-rs/keyring) post-MVP.
# =====================================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Model defaults (override per-call via router) ---
HUB_DEFAULT_MODEL=claude-sonnet-4-5
HUB_LOCAL_MODEL_TRIVIAL=phi4-mini
HUB_LOCAL_MODEL_PRIVATE=qwen3:7b
HUB_LOCAL_MODEL_FALLBACK=llama3.3

# --- Ollama ---
OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- Notion ---
NOTION_TOKEN=
NOTION_VERSION=2025-09-03

# --- Obsidian (Local REST API plugin) ---
OBSIDIAN_API_KEY=
OBSIDIAN_HOST=127.0.0.1
OBSIDIAN_PORT=27123
OBSIDIAN_VAULT_PATH=

# --- Google Workspace (workspace-mcp) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Todoist (sjvadrevu MCP — permanent token, NOT OAuth) ---
TODOIST_API_TOKEN=
TODOIST_MCP_PATH=./vendor/todoist-mcp-server/dist/index.js

# --- Linear (remote MCP, OAuth handled by SDK) ---
# no env needed; SDK manages OAuth

# --- GitHub ---
GITHUB_PAT=

# --- Server ---
HUB_PORT=4567
HUB_HOST=127.0.0.1
HUB_TIMEZONE=America/Chicago

# --- Database ---
HUB_DB_PATH=./data/hub.db

# --- Logging ---
HUB_LOG_LEVEL=info
HUB_LOG_DIR=./logs

# --- Notifications ---
NTFY_TOPIC=
NTFY_URL=https://ntfy.sh

# --- Privacy router (load-bearing: enforced from MVP day 1) ---
# Comma-separated regex patterns. Match in user input => route to local SLM, never Anthropic.
HUB_SENSITIVITY_PATTERNS=medical|prescription|diagnosis|therapist,SSN|social.security,bank.*account|routing.*number,salary|compensation,family|wife|kid|child

# --- Cost ceiling ---
# When today's cumulative Anthropic spend reaches this USD cap, the router
# silently downgrades cloud routes to HUB_LOCAL_MODEL_FALLBACK. 0 disables.
HUB_DAILY_USD_CAP=5

# --- Webhook shared secret ---
# Required for all /webhooks/* endpoints (Superwhisper, Granola, etc.).
# Empty => server returns 503 on every webhook. Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
HUB_WEBHOOK_SECRET=

